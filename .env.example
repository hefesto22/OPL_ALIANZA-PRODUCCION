APP_NAME="Distribuidora Hozana"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://distribuidora-hozana.test
APP_TIMEZONE=America/Tegucigalpa

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_HN

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Base de datos ────────────────────────────────────────────────────────────
# En local/producción se usa PostgreSQL 16 (ver docker-compose.yml).
# Los tests (phpunit.xml) corren contra la BD hozana_test en el mismo
# Postgres — crearla una vez con:
#   docker compose exec postgres psql -U postgres -c "CREATE DATABASE hozana_test;"
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=distribuidora_hozana
DB_USERNAME=postgres
DB_PASSWORD=secret

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Cache, sesiones y colas viajan todas por Redis — requisito para soportar
# múltiples instancias detrás de un load balancer.
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

MEMCACHED_HOST=127.0.0.1

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── Integración Jaremar ──────────────────────────────────────────────────────
# API key compartida con el OPL de Jaremar para los endpoints /api/v1/*.
# En producción debe rotarse y guardarse SOLO en el .env del servidor.
JAREMAR_API_KEY=

# Rate limits de la API (se pueden ajustar sin redeploy)
API_RATE_LIMIT=60
API_RATE_LIMIT_INSERTAR=5
API_RATE_LIMIT_DEVOLUCIONES=10

# ── Límite de seguridad para reportes PDF ────────────────────────────────────
# Número máximo de filas que los reportes de impresión pueden traer en una
# sola solicitud. Protege la memoria del proceso PHP ante rangos amplios.
REPORTS_MAX_ROWS=5000
